{
  "name": "gov-eservices-backend",
  "version": "1.0.0",
  "description": "GOV E-Services Portal - Backend API Server",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "prisma:generate": "npx prisma generate --schema=src/prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --schema=src/prisma/schema.prisma",
    "prisma:push": "npx prisma db push --schema=src/prisma/schema.prisma",
    "prisma:studio": "npx prisma studio --schema=src/prisma/schema.prisma",
    "seed": "node src/prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "otplib": "^13.4.1",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  }
}
