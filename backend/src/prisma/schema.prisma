// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum AdminRole {
  super_admin
  admin
  officer
  reviewer
}

enum UserStatus {
  active
  inactive
  suspended
  pending_verification
}

enum AdminStatus {
  active
  inactive
  suspended
}

enum ServiceStatus {
  active
  inactive
}

enum SchemeStatus {
  active
  inactive
  expired
}

enum ApplicationStatus {
  draft
  pending
  in_progress
  document_verification
  payment_pending
  payment_completed
  approved
  rejected
  on_hold
  correction_required
  completed
}

enum PaymentStatus {
  pending
  success
  failed
  refunded
}

enum PaymentMethod {
  upi
  credit_card
  debit_card
  net_banking
  wallet
}

enum ApplicationPriority {
  low
  medium
  high
  urgent
}

enum DocumentStatus {
  pending
  approved
  rejected
}

enum NotificationRecipientType {
  user
  admin
}

enum NotificationType {
  email
  sms
  in_app
}

enum NotificationStatus {
  pending
  sent
  failed
  read
}

enum Gender {
  male
  female
  other
}

enum ContactMessageStatus {
  new
  in_progress
  resolved
  closed
}

enum GrievanceStatus {
  open
  in_progress
  escalated
  resolved
  closed
}

enum GrievancePriority {
  low
  medium
  high
  critical
}

enum AppointmentStatus {
  scheduled
  confirmed
  completed
  cancelled
  no_show
}

enum OTPType {
  email_verification
  mobile_verification
  password_reset
}

enum TransactionType {
  deposit
  withdrawal
  payment
  refund
}

enum TransactionStatus {
  pending
  completed
  failed
  cancelled
}

enum DocumentCategory {
  identity
  address
  income
  educational
  medical
  other
}

// ============================================================================
// MODELS
// ============================================================================

model Admin {
  id          Int         @id @default(autoincrement())
  adminId     String      @unique @map("admin_id")
  name        String      @db.VarChar(100)
  email       String      @unique @db.VarChar(100)
  mobile      String      @unique @db.VarChar(15)
  password    String      @db.VarChar(255)
  role        AdminRole   @default(admin)
  department  String?     @db.VarChar(100)
  designation String?     @db.VarChar(100)
  permissions Json?
  twoFactorSecret String?     @map("two_factor_secret") @db.VarChar(100)
  twoFactorEnabled Boolean    @default(false) @map("two_factor_enabled")
  status      AdminStatus @default(active)
  lastLogin   DateTime?   @map("last_login")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  createdServices      Service[]        @relation("ServiceCreatedBy")
  createdSchemes       Scheme[]         @relation("SchemeCreatedBy")
  reviewedDocuments    Document[]       @relation("DocumentReviewedBy")
  assignedApplications Application[]    @relation("ApplicationAssignedTo")
  auditLogs            AuditLog[]
  notifications        Notification[]   @relation("AdminNotifications")
  respondedMessages    ContactMessage[] @relation("MessageRespondedBy")
  assignedGrievances   Grievance[]      @relation("GrievanceAssignedTo")
  chatSessions         ChatSession[]    @relation("ChatSessionAdmin")
  sentChatMessages     ChatMessage[]    @relation("MessageSenderAdmin")
  tasks                Task[]           @relation("AdminTasks")

  @@index([adminId])
  @@index([email])
  @@index([role])
  @@index([status])
  @@map("admins")
}

model User {
  id                 Int        @id @default(autoincrement())
  userId             String     @unique @map("user_id")
  name               String     @db.VarChar(100)
  email              String     @unique @db.VarChar(100)
  mobile             String     @unique @db.VarChar(15)
  aadhaarNumber      String?    @unique @map("aadhaar_number") @db.VarChar(12)
  panNumber          String?    @map("pan_number") @db.VarChar(10)
  dateOfBirth        DateTime?  @map("date_of_birth") @db.Date
  gender             Gender?
  address            String?    @db.Text
  city               String?    @db.VarChar(100)
  state              String?    @db.VarChar(50)
  pincode            String?    @db.VarChar(6)
  password           String     @db.VarChar(255)
  profilePhoto       String?    @map("profile_photo") @db.VarChar(255)
  status             UserStatus @default(pending_verification)
  emailVerified      Boolean    @default(false) @map("email_verified")
  mobileVerified     Boolean    @default(false) @map("mobile_verified")
  emailNotifications Boolean    @default(true) @map("email_notifications")
  smsNotifications   Boolean    @default(true) @map("sms_notifications")
  lastLogin          DateTime?  @map("last_login")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  deletedAt          DateTime?  @map("deleted_at")

  // Relations
  applications  Application[]
  documents     Document[]
  notifications Notification[]    @relation("UserNotifications")
  savedSchemes  UserSavedScheme[]
  grievances    Grievance[]
  feedbacks     Feedback[]
  appointments  Appointment[]
  loginHistory  LoginHistory[]
  wallet        Wallet?
  digitalLocker DigitalLockerItem[]
  chatSessions  ChatSession[]
  sentChatMessages ChatMessage[]    @relation("MessageSenderUser")
  tasks         Task[]           @relation("UserTasks")

  @@index([userId])
  @@index([email])
  @@index([mobile])
  @@index([aadhaarNumber])
  @@index([status])
  @@map("users")
}

model Service {
  id                Int           @id @default(autoincrement())
  serviceCode       String        @unique @map("service_code") @db.VarChar(20)
  name              String        @db.VarChar(200)
  description       String?       @db.Text
  category          String?       @db.VarChar(50)
  department        String?       @db.VarChar(100)
  requiredDocuments String?       @map("required_documents") @db.Text
  processingTime    String?       @map("processing_time") @db.VarChar(50)
  fees              Decimal       @default(0) @db.Decimal(10, 2)
  officialWebsite   String?       @map("official_website") @db.VarChar(255)
  logoUrl           String?       @map("logo_url") @db.VarChar(500)
  status            ServiceStatus @default(active)
  createdById       Int?          @map("created_by")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  // Relations
  createdBy    Admin?        @relation("ServiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  applications Application[]

  @@index([serviceCode])
  @@index([category])
  @@index([status])
  @@map("services")
}

model Scheme {
  id          Int          @id @default(autoincrement())
  schemeCode  String       @unique @map("scheme_code") @db.VarChar(20)
  name        String       @db.VarChar(200)
  description String?      @db.Text
  category    String?      @db.VarChar(50)
  eligibility String?      @db.Text
  benefits    String?      @db.Text
  state       String?      @db.VarChar(50)
  department  String?      @db.VarChar(100)
  applicationFee Decimal   @default(0) @map("application_fee") @db.Decimal(10, 2)
  officialWebsite String?  @map("official_website") @db.VarChar(255)
  logoUrl         String?  @map("logo_url") @db.VarChar(500)
  startDate   DateTime?    @map("start_date") @db.Date
  endDate     DateTime?    @map("end_date") @db.Date
  status      SchemeStatus @default(active)
  createdById Int?         @map("created_by")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // Relations
  createdBy    Admin?            @relation("SchemeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  savedByUsers UserSavedScheme[]

  @@index([schemeCode])
  @@index([category])
  @@index([state])
  @@index([status])
  @@map("schemes")
}

model Application {
  id                Int                 @id @default(autoincrement())
  userId            Int                 @map("user_id")
  serviceId         Int                 @map("service_id")
  applicationNumber String              @unique @map("application_number") @db.VarChar(50)
  status            ApplicationStatus   @default(pending)
  submittedData     Json?               @map("submitted_data")
  remarks           String?             @db.Text
  assignedToId      Int?                @map("assigned_to")
  priority          ApplicationPriority @default(medium)
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  deletedAt         DateTime?           @map("deleted_at")

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  service    Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  assignedTo Admin?     @relation("ApplicationAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  documents  Document[]
  payments   Payment[]
  grievances Grievance[]

  @@index([userId])
  @@index([serviceId])
  @@index([applicationNumber])
  @@index([status])
  @@index([assignedToId])
  @@map("service_applications")
}

model Document {
  id           Int            @id @default(autoincrement())
  userId       Int            @map("user_id")
  applicationId Int?          @map("application_id")
  documentType String         @map("document_type") @db.VarChar(100)
  documentName String         @map("document_name") @db.VarChar(255)
  filePath     String         @map("file_path") @db.VarChar(500)
  fileSize     Int            @map("file_size")
  fileType     String         @map("file_type") @db.VarChar(50)
  status       DocumentStatus @default(pending)
  adminRemarks String?        @map("admin_remarks") @db.Text
  reviewedById Int?           @map("reviewed_by")
  reviewedAt   DateTime?      @map("reviewed_at")
  uploadedAt   DateTime       @default(now()) @map("uploaded_at")

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  reviewedBy  Admin?       @relation("DocumentReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([applicationId])
  @@index([reviewedById])
  @@map("document_uploads")
}

model Notification {
  id            Int                       @id @default(autoincrement())
  userId        Int?                      @map("user_id")
  adminId       Int?                      @map("admin_id")
  recipientType NotificationRecipientType @map("recipient_type")
  type          NotificationType
  recipient     String                    @db.VarChar(255)
  subject       String?                   @db.VarChar(255)
  message       String                    @db.Text
  status        NotificationStatus        @default(pending)
  errorMessage  String?                   @map("error_message") @db.Text
  isRead        Boolean                   @default(false) @map("is_read")
  createdAt     DateTime                  @default(now()) @map("created_at")
  sentAt        DateTime?                 @map("sent_at")
  readAt        DateTime?                 @map("read_at")

  // Relations
  user  User?  @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  admin Admin? @relation("AdminNotifications", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([adminId])
  @@index([recipientType])
  @@index([type])
  @@index([status])
  @@map("notifications")
}

model UserSavedScheme {
  id       Int      @id @default(autoincrement())
  userId   Int      @map("user_id")
  schemeId Int      @map("scheme_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheme Scheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)

  @@unique([userId, schemeId])
  @@index([userId])
  @@index([schemeId])
  @@map("user_saved_schemes")
}

model News {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  content     String    @db.Text
  category    String?   @db.VarChar(50)
  imageUrl    String?   @map("image_url") @db.VarChar(500)
  isActive    Boolean   @default(true) @map("is_active")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("news")
}

model ContactMessage {
  id            Int                  @id @default(autoincrement())
  name          String               @db.VarChar(100)
  email         String               @db.VarChar(100)
  phone         String?              @db.VarChar(15)
  subject       String               @db.VarChar(255)
  message       String               @db.Text
  status        ContactMessageStatus @default(new)
  respondedById Int?                 @map("responded_by")
  respondedAt   DateTime?            @map("responded_at")
  createdAt     DateTime             @default(now()) @map("created_at")

  // Relations
  respondedBy Admin? @relation("MessageRespondedBy", fields: [respondedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("contact_messages")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  adminId     Int      @map("admin_id")
  action      String   @db.VarChar(100)
  targetType  String?  @map("target_type") @db.VarChar(50)
  targetId    Int?     @map("target_id")
  description String?  @db.Text
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_activity_log")
}

model Job {
  id              Int       @id @default(autoincrement())
  jobCode         String    @unique @map("job_code") @db.VarChar(20)
  title           String    @db.VarChar(200)
  department      String    @db.VarChar(150)
  state           String    @db.VarChar(50)
  category        String?   @db.VarChar(100)
  qualification   String?   @db.Text
  ageLimit        String?   @map("age_limit") @db.VarChar(100)
  deadline        DateTime? @db.Date
  salary          String?   @db.VarChar(100)
  jobType         String?   @map("job_type") @db.VarChar(50)
  description     String?   @db.Text
  officialWebsite String?   @map("official_website") @db.VarChar(255)
  logoUrl         String?   @map("logo_url") @db.VarChar(500)
  notificationPdf String?   @map("notification_pdf") @db.VarChar(500)
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([state])
  @@index([category])
  @@index([isActive])
  @@map("jobs")
}

model Payment {
  id              Int           @id @default(autoincrement())
  transactionId   String        @unique @map("transaction_id") @db.VarChar(100)
  applicationId   Int           @map("application_id")
  amount          Decimal       @db.Decimal(10, 2)
  status          PaymentStatus @default(pending)
  method          PaymentMethod?
  paymentDate     DateTime?     @map("payment_date")
  receiptUrl      String?       @map("receipt_url") @db.VarChar(500)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  application     Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([transactionId])
  @@index([status])
  @@map("payments")
}

model FAQ {
  id        Int      @id @default(autoincrement())
  question  String   @db.VarChar(500)
  answer    String   @db.Text
  category  String?  @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([isActive])
  @@map("faqs")
}

// ============================================================================
// NEW FEATURE MODELS
// ============================================================================

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String   @db.VarChar(100)
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}

model OTPVerification {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  email     String?  @db.VarChar(100)
  mobile    String?  @db.VarChar(15)
  otpHash   String   @map("otp_hash") @db.VarChar(255)
  type      OTPType
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([mobile])
  @@index([userId])
  @@map("otp_verifications")
}

model Grievance {
  id               Int               @id @default(autoincrement())
  userId           Int               @map("user_id")
  applicationId    Int?              @map("application_id")
  grievanceNumber  String            @unique @map("grievance_number") @db.VarChar(50)
  subject          String            @db.VarChar(255)
  description      String            @db.Text
  category         String?           @db.VarChar(100)
  status           GrievanceStatus   @default(open)
  priority         GrievancePriority @default(medium)
  assignedToId     Int?              @map("assigned_to")
  resolution       String?           @db.Text
  resolvedAt       DateTime?         @map("resolved_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  assignedTo  Admin?       @relation("GrievanceAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([applicationId])
  @@index([status])
  @@index([grievanceNumber])
  @@map("grievances")
}

model Feedback {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  serviceId     Int?     @map("service_id")
  applicationId Int?     @map("application_id")
  rating        Int      @default(5)
  comment       String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([serviceId])
  @@index([applicationId])
  @@map("feedbacks")
}

model Appointment {
  id                 Int               @id @default(autoincrement())
  userId             Int               @map("user_id")
  serviceId          Int?              @map("service_id")
  confirmationNumber String            @unique @map("confirmation_number") @db.VarChar(50)
  appointmentDate    DateTime          @map("appointment_date") @db.Date
  timeSlot           String            @map("time_slot") @db.VarChar(50)
  officeLocation     String?           @map("office_location") @db.VarChar(255)
  purpose            String?           @db.VarChar(255)
  notes              String?           @db.Text
  status             AppointmentStatus @default(scheduled)
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([serviceId])
  @@index([appointmentDate])
  @@index([status])
  @@map("appointments")
}

model LoginHistory {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.Text
  loginAt   DateTime @default(now()) @map("login_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loginAt])
  @@map("login_history")
}

// ============================================================================
// PHASE 2 & 3 ADVANCED MODELS
// ============================================================================

model Wallet {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  currency  String   @default("INR") @db.VarChar(10)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id            Int               @id @default(autoincrement())
  walletId      Int               @map("wallet_id")
  transactionId String            @unique @map("transaction_id") @db.VarChar(100)
  type          TransactionType
  amount        Decimal           @db.Decimal(10, 2)
  balanceAfter  Decimal           @map("balance_after") @db.Decimal(12, 2)
  description   String?           @db.VarChar(255)
  status        TransactionStatus @default(completed)
  createdAt     DateTime          @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([transactionId])
  @@map("wallet_transactions")
}

model DigitalLockerItem {
  id           Int              @id @default(autoincrement())
  userId       Int              @map("user_id")
  documentId   String           @unique @map("document_id") @db.VarChar(50)
  name         String           @db.VarChar(200)
  category     DocumentCategory
  filePath     String           @map("file_path") @db.VarChar(500)
  fileType     String           @map("file_type") @db.VarChar(50)
  fileSize     Int              @map("file_size")
  isVerified   Boolean          @default(false) @map("is_verified")
  issuedBy     String?          @map("issued_by") @db.VarChar(150)
  issueDate    DateTime?        @map("issue_date") @db.Date
  expiryDate   DateTime?        @map("expiry_date") @db.Date
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@map("digital_locker_items")
}

model ChatSession {
  id         Int       @id @default(autoincrement())
  sessionId  String    @unique @map("session_id") @db.VarChar(50)
  userId     Int       @map("user_id")
  adminId    Int?      @map("admin_id")
  topic      String?   @db.VarChar(200)
  isActive   Boolean   @default(true) @map("is_active")
  startedAt  DateTime  @default(now()) @map("started_at")
  endedAt    DateTime? @map("ended_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin    Admin?        @relation("ChatSessionAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@index([userId])
  @@index([adminId])
  @@index([isActive])
  @@map("chat_sessions")
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  sessionId Int      @map("session_id")
  senderType NotificationRecipientType @map("sender_type")
  senderUserId  Int?  @map("sender_user_id")
  senderAdminId Int?  @map("sender_admin_id")
  content   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  senderUser  User?       @relation("MessageSenderUser", fields: [senderUserId], references: [id], onDelete: SetNull)
  senderAdmin Admin?      @relation("MessageSenderAdmin", fields: [senderAdminId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@map("chat_messages")
}

model Task {
  id           Int       @id @default(autoincrement())
  title        String    @db.VarChar(255)
  description  String?   @db.Text
  status       String    @default("pending") // pending, in_progress, completed
  priority     String    @default("medium") // low, medium, high
  assignedToId Int?      @map("assigned_to_id")
  userId       Int?      @map("user_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  assignedTo   Admin?    @relation("AdminTasks", fields: [assignedToId], references: [id], onDelete: SetNull)
  user         User?     @relation("UserTasks", fields: [userId], references: [id], onDelete: SetNull)

  @@index([assignedToId])
  @@index([userId])
  @@index([status])
  @@map("tasks")
}
